# ─── Prismalia Auditor - Variables de Entorno ───

# Google Gemini API key (para consejos de corrección con IA)
GEMINI_API_KEY=your_gemini_api_key_here

# Contraseña de acceso al sistema
AUTH_PASSWORD=admin123

# PostgreSQL connection string
# Railway inyecta esto automáticamente al vincular el plugin PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/accessibility_db

# Puerto del servidor (Railway lo inyecta automáticamente)
# PORT=8080
